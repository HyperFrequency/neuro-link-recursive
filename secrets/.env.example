# neuro-link-recursive secrets
# Copy this to .env and fill in your keys.
# This file is .gitignored — never commit .env

# Required for Phase 1
INFRANODUS_API_KEY=
FIRECRAWL_API_KEY=
CONTEXT7_API_KEY=
OPENROUTER_API_KEY=

# Phase 2 — Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Phase 2 — Embeddings
EMBEDDING_MODEL=Octen-8B
EMBEDDING_DIM=4096

# Phase 3 — Harness Bridge
NGROK_AUTH_TOKEN=
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Phase 3 — K-Dense
KDENSE_API_KEY=
KDENSE_URL=http://localhost:3000

# Phase 3 — Cloud Compute
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
