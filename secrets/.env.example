# neuro-link secrets template — copy to .env and fill in.
# .env is .gitignored, this file is safe to commit.

# ── LLM Providers ──
# Used by neuro-link's /llm/v1 passthrough proxy.
# In your CLI tool: ANTHROPIC_BASE_URL=http://localhost:8080/llm/v1
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Knowledge & Research ──
PARALLEL_API_KEY=
INFRANODUS_API_KEY=

# ── Local Infrastructure ──
EMBEDDING_API_URL=http://localhost:8400/v1/embeddings
EMBEDDING_MODEL=Octen/Octen-Embedding-8B
EMBEDDING_DIMS=4096
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_URL=http://localhost:7474
NEO4J_USER=neo4j
# NEO4J_PASSWORD must be set before `docker compose up` — docker-compose.yml
# uses `${NEO4J_PASSWORD:?...}` and will abort if it's missing. `setup-deps.sh`
# auto-generates a 32-char random password on first run if this is empty.
# To rotate, see docs/rotate-neo4j-password.md.
NEO4J_PASSWORD=

# ── Tunneling ──
NGROK_AUTH_TOKEN=

# ── neuro-link auth (auto-generated on first `neuro-link serve --token auto`) ──
NLR_API_TOKEN=
